{"t":"2026-06-03T20:04:51.445Z","level":"info","cat":"ipc","action":"terminal:exec:ok","detail":{"ms":4845,"result":{"stdout":"import { marked, Renderer } from 'marked';\n\n// Override the HTML renderer to escape raw HTML blocks instead of passing them through.\n// This prevents any HTML injected in AI responses from executing (XSS hardening).\nconst renderer = new Renderer();\nrenderer.html = ({ raw }: { raw: string }) =>\n  raw.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');\n\nmarked.use({ renderer, gfm: true, breaks: true });\n\nexport function renderMarkdown(text: string): string {\n  try {\n    return marked.parse(text, { async: false }) as string;\n  } catch {\n    return `<p>${text.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</p>`;\n  }\n}\n","stderr":"","code":0}}}
