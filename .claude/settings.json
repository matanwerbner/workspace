{
  "permissions": {
    "allow": [
      "Bash(npm view *)",
      "Bash(npx vitest run *)",
      "Bash(npm run typecheck:web *)",
      "Bash(npm run typecheck:node *)",
      "Bash(npm run typecheck *)",
      "Bash(npx tsc --noEmit *)",
      "Bash(npm test -- *)",
      "Bash(screencapture *)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Ping.aiff"
          }
        ]
      }
    ]
  }
}
